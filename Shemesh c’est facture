<script>
const TVA = 0.17;
const PRIX_WC = 0.45;
const POSE_BAT = 1000;
const POSE_SANS = 750;

const BAT_PRIX = {5:4200,10:8400,15:12600,20:12600,25:16800,30:16800};
const BAT_DESC = {5:'5 kWh (1×5kWh)',10:'10 kWh (2×5kWh)',15:'15 kWh (3×5kWh)',20:'15 kWh (3×5kWh)',25:'20 kWh (4×5kWh)',30:'20 kWh (4×5kWh)'};
const ONDULEUR = {5:3500,10:6500,15:8000,20:9240,25:11000,30:13500};
const FIXATION = {5:900,10:1800,15:2600,20:3200,25:4000,30:4800};
const CABLAGE  = {5:700,10:1100,15:1500,20:1800,25:2200,30:2600};
const CONNECT  = {5:280,10:400,15:550,20:650,25:800,30:950};
const IEC      = {5:900,10:1300,15:1600,20:1800,25:2100,30:2400};
const MES      = {5:400,10:600,15:750,20:900,25:1100,30:1200};
const TRANSPORT= {5:300,10:450,15:600,20:700,25:850,30:1000};
const DIGITAL  = {5:600,10:1200,15:1800,20:2500,25:3200,30:4000};
const VISITE   = {5:250,10:350,15:500,20:600,25:700,30:900};
const PRIX_TTC = {5:18900,10:35900,15:54900,20:79900,25:99900,30:119900};
const PACKS    = [5,10,15,20,25,30];
const COLORS   = {mat:'#3B82F6',pose:'#F59E0B',acq:'#8B5CF6',marge:'#2D9E6B',tva:'#F97316'};

let kwc=20, withBat=true, showAcq=true, mode='ttc';
let customTTC=null; // null = prix cible par défaut
let charts={};

function getBaseTTC(){return PRIX_TTC[kwc];}
function getEffTTC(){return customTTC!==null?customTTC:getBaseTTC();}


// ─── ROI ──────────────────────────────────────────────────────────────────────
const EXPO = {
  sud:   { kwcPerKwc: 1750, label: 'Sud (1 750 kWh/kWc/an)' },
  est:   { kwcPerKwc: 1550, label: 'Est (1 550 kWh/kWc/an)' },
  ouest: { kwcPerKwc: 1550, label: 'Ouest (1 550 kWh/kWc/an)' },
  nord:  { kwcPerKwc: 1150, label: 'Nord (1 150 kWh/kWc/an)' },
};
let currentExpo = 'sud';
let withPrime = false;
let roiYears = 25;

function setExpo(el, expo) {
  currentExpo = expo;
  document.querySelectorAll('.expo-btn[data-expo]').forEach(b => b.classList.toggle('active', b.dataset.expo === expo));
  renderROI();
}

function togglePrime() {
  withPrime = !withPrime;
  const t = document.getElementById('tgl-prime');
  t.classList.toggle('on-orange', withPrime);
  const knob = t.querySelector('.tgl-knob');
  if(knob) knob.style.background = '#fff';
  document.getElementById('prime-lbl').textContent = withPrime ? '0,47 ₪/kWh' : '0,41 ₪/kWh';
  document.getElementById('prime-sub').textContent = withPrime ? 'Avec prime urbaine' : 'Tarif standard';
  renderROI();
}

function setYears(y) {
  roiYears = y;
  document.getElementById('yr-10').classList.toggle('active', y===10);
  document.getElementById('yr-25').classList.toggle('active', y===25);
  renderROI();
}

function renderROI() {
  const k = kwc;
  const expo = EXPO[currentExpo];
  const tarif = withPrime ? 0.47 : 0.41;
  const prodAn = Math.round(k * expo.kwcPerKwc);
  const revAn = Math.round(prodAn * tarif);
  const invest = getEffTTC();
  const roiAns = (invest / revAn).toFixed(1);
  const cumul = Math.round(revAn * roiYears);
  const gain = cumul - invest;
  const pct = Math.min(Math.round((roiYears / parseFloat(roiAns)) * 100), 100);

  document.getElementById('roi-prod').textContent = prodAn.toLocaleString('fr-FR') + ' kWh';
  document.getElementById('roi-kwc').textContent = expo.label;
  document.getElementById('roi-rev').textContent = fmt(revAn) + '/an';
  document.getElementById('roi-tarif').textContent = tarif + ' ₪/kWh × ' + prodAn.toLocaleString('fr-FR') + ' kWh';
  document.getElementById('roi-years').textContent = roiAns + ' ans';
  document.getElementById('roi-horizon-lbl').textContent = 'Cumul ' + roiYears + ' ans';
  document.getElementById('roi-cumul').textContent = fmt(cumul);
  document.getElementById('roi-gain').textContent = (gain >= 0 ? '+ ' : '') + fmt(gain) + ' de bénéfice net';
  document.getElementById('roi-gain').style.color = gain >= 0 ? '#2D9E6B' : '#E05252';
  document.getElementById('roi-pct-lbl').textContent = pct + '% remboursé sur ' + roiYears + ' ans';
  document.getElementById('roi-bar').style.width = pct + '%';
  document.getElementById('roi-bar').style.background = pct >= 100 ? '#2D9E6B' : 'linear-gradient(90deg,#2D9E6B,#F5A623)';
  document.getElementById('roi-invest').textContent = fmt(invest);
  document.getElementById('roi-horizon-end').textContent = 'Horizon ' + roiYears + ' ans';

  // Tableau par période
  const periods = [];
  for(let i=1; i<=7; i++) periods.push(i);
  for(let i=10; i<=roiYears; i+=5) periods.push(i);
  if(!periods.includes(roiYears)) periods.push(roiYears);

  const rows = periods.map(p => {
    const c = Math.round(revAn * p);
    const g = c - invest;
    const ok = c >= invest;
    return `<tr>
      <td><strong>${p} an${p>1?'s':''}</strong></td>
      <td>${fmt(c)}</td>
      <td style="color:${ok?'#2D9E6B':'#E05252'};font-weight:700">${ok?'+ ':''} ${fmt(g)}</td>
      <td><div style="height:6px;background:#F1F5F9;border-radius:3px;overflow:hidden;width:100px"><div style="height:100%;width:${Math.min(Math.round(c/invest*100),100)}%;background:${ok?'#2D9E6B':'#F5A623'};border-radius:3px"></div></div></td>
    </tr>`;
  }).join('');

  document.getElementById('roi-table').innerHTML =
    `<tr style="border-bottom:2px solid var(--border)">
      <td style="font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted)">Période</td>
      <td style="font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted)">Cumul revenus</td>
      <td style="font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted)">Gain net</td>
      <td style="font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted)">Avancement</td>
    </tr>` + rows;
}

function initSlider(){
  const base=getBaseTTC();
  const min=5000;
  const max=200000;
  const range=document.getElementById('price-range');
  range.min=min; range.max=max; range.step=5000;

  const cur=customTTC!==null?customTTC:base;
  range.value=cur;
  // ticks
  document.getElementById('tick-min').textContent=fmt(min);
  document.getElementById('tick-max').textContent=fmt(max);
  document.getElementById('tick-mid').textContent='Cible : '+fmt(base);
  updateSliderDisplay(cur);
  // gradient
  updateRangeGradient(range);
}

function updateRangeGradient(range){
  const pct=(range.value-range.min)/(range.max-range.min)*100;
  range.style.background=`linear-gradient(to right,#F5A623 0%,#F5A623 ${pct}%,rgba(255,255,255,0.15) ${pct}%,rgba(255,255,255,0.15) 100%)`;
}

function updateSliderDisplay(ttcVal){
  const htVal=Math.round(ttcVal/(1+TVA));
  document.getElementById('slider-display').innerHTML=fmt(ttcVal)+'<small> TTC</small>';
  document.getElementById('slider-ht-badge').textContent=fmt(htVal)+' HT';
}

function onSlider(val){
  customTTC=parseInt(val);
  updateSliderDisplay(customTTC);
  updateRangeGradient(document.getElementById('price-range'));
  render();
}

function resetPrice(){
  customTTC=null;
  initSlider();
  render();
}

// Init pack buttons
const packRow = document.getElementById('pack-row');
PACKS.forEach(k => {
  const b = document.createElement('button');
  b.className='pack-btn'+(k===kwc?' active':'');
  b.textContent=k+' kWc';
  b.onclick=()=>setPack(k);
  packRow.appendChild(b);
});

function setPack(k){kwc=k;customTTC=null;document.querySelectorAll('.pack-btn').forEach((b,i)=>b.classList.toggle('active',PACKS[i]===k));initSlider();render()}

function toggleBat(){
  withBat=!withBat;
  const t=document.getElementById('tgl-bat'),tag=document.getElementById('tag-bat');
  t.classList.toggle('on',withBat);
  tag.textContent=withBat?'Avec batterie':'Sans batterie';
  tag.classList.toggle('on',withBat);
  render();
}

function toggleAcq(){
  showAcq=!showAcq;
  const t=document.getElementById('tgl-acq'),tag=document.getElementById('tag-acq');
  t.classList.toggle('on-orange',showAcq);
  tag.textContent=showAcq?'Incluse':'Masquée';
  tag.classList.toggle('on-orange',showAcq);
  // dim acquisition card + kpi
  const cardAcq = document.getElementById('card-acq');
  const kpiAcq = document.getElementById('kpi-acq-card');
  cardAcq.style.display = showAcq ? '' : 'none';
  kpiAcq.style.display = showAcq ? '' : 'none';
  render();
}

function setMode(m){
  mode=m;
  document.getElementById('btn-ht').classList.toggle('active',m==='ht');
  document.getElementById('btn-ttc').classList.toggle('active',m==='ttc');
  render();
}

// fmt: applies HT/TTC mode. All costs are HT, prix vente can be HT or TTC.
function fmt(n){return Math.round(n).toLocaleString('fr-FR')+' ₪'}
function pct(a,b){return Math.round(a/b*100)+'%'}
// Display a cost value in current mode (costs are HT — multiply by 1+TVA for TTC display)
function fmtCost(n){return fmt(mode==='ttc'? n*(1+TVA) : n)}
// Display price (already has both HT and TTC computed)
function fmtPrice(ht,ttc){return fmt(mode==='ttc'?ttc:ht)}
function modeLabel(){return mode==='ttc'?'TTC':'HT'}

function makeTable(rows,totalHT){
  return rows.map(r=>`<tr><td>${r.l}</td><td>${r.q}</td><td>${fmtCost(r.v)}</td></tr>`).join('')
    +`<tr class="sub"><td colspan="2">SOUS-TOTAL ${modeLabel()}</td><td>${fmtCost(totalHT)}</td></tr>`;
}

function makePie(id,legId,labels,values,colors,dimIdx){
  if(charts[id])charts[id].destroy();
  const ctx=document.getElementById(id).getContext('2d');
  charts[id]=new Chart(ctx,{
    type:'doughnut',
    data:{labels,datasets:[{data:values,backgroundColor:colors,borderWidth:2,borderColor:'#fff',hoverOffset:6}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'62%',
      plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>` ${c.label}: ${fmt(c.raw)} (${Math.round(c.raw/c.dataset.data.reduce((a,b)=>a+b,0)*100)}%)`}}}}
  });
  const total=values.reduce((a,b)=>a+b,0);
  document.getElementById(legId).innerHTML=labels.map((l,i)=>
    `<div class="leg-item${dimIdx&&dimIdx.includes(i)?' dimmed':''}">
      <div class="leg-dot" style="background:${colors[i]}"></div>
      <span>${l} — <strong>${pct(values[i],total)}</strong></span>
    </div>`
  ).join('');
}

function toggleMarge(){
  const body=document.getElementById('body-marge');
  const btn=document.getElementById('btn-marge');
  if(!body)return;
  const collapsed=body.classList.toggle('collapsed');
  if(btn)btn.textContent=collapsed?'▼':'▲';
}

function toggleCard(bodyId, btnId){
  const body = document.getElementById(bodyId);
  const btn  = document.getElementById(btnId);
  if(!body) return;
  const collapsed = body.classList.toggle('collapsed');
  if(btn) btn.textContent = collapsed ? '▼' : '▲';
}

function render(){
  const k=kwc, wb=withBat, sa=showAcq;

  // MATÉRIEL (HT)
  const panneaux=Math.round(k*1000*PRIX_WC);
  const nP=Math.ceil(k*1000/550);
  const matRows=[
    {l:`${nP}× Panneaux Jinko 550W (0,45₪/Wc)`,q:`${nP} u.`,v:panneaux},
    {l:`Onduleur hybride ${k}kW (Huawei/SolarEdge)`,q:'1 u.',v:ONDULEUR[k]},
    ...(wb?[{l:`Batterie LiFePO4 ${BAT_DESC[k]}`,q:'1 u.',v:BAT_PRIX[k]}]:[]),
    {l:'Kit fixation K2 Systems',q:'1 kit',v:FIXATION[k]},
    {l:'Câblage DC/AC + protections',q:'forfait',v:CABLAGE[k]},
    {l:'Connecteurs, disjoncteurs, terre',q:'forfait',v:CONNECT[k]},
  ];
  const matHT=matRows.reduce((a,r)=>a+r.v,0);

  // POSE (HT)
  const moMain=k*(wb?POSE_BAT:POSE_SANS);
  const poseRows=[
    {l:`Main-d'oeuvre (${k}kWc × ${wb?1000:750}₪/kWc)`,q:`${k} kWc`,v:moMain},
    {l:'Démarches IEC + permis mairie',q:'forfait',v:IEC[k]},
    {l:'Mise en service & tests',q:'forfait',v:MES[k]},
    {l:'Transport & logistique',q:'forfait',v:TRANSPORT[k]},
  ];
  const poseHT=poseRows.reduce((a,r)=>a+r.v,0);

  // ACQUISITION (HT)
  const ttc=getEffTTC();
  const baseTTC=getBaseTTC();
  const commission=Math.round(ttc*0.03);
  const acqRows=[
    {l:'Publicité digitale (Meta/Google)',q:'par lead',v:DIGITAL[k]},
    {l:'Commission commercial (3% CA TTC)',q:'3%',v:commission},
    {l:'Dossier, visite technique',q:'forfait',v:VISITE[k]},
  ];
  const acqHT=acqRows.reduce((a,r)=>a+r.v,0);
  const acqEffHT=sa?acqHT:0;

  // CALCULS
  const coutRevHT=matHT+poseHT+acqEffHT;
  const prixHT=Math.round(ttc/(1+TVA));
  const tvaAmt=ttc-prixHT;
  const margeHT=prixHT-coutRevHT;
  const margePct=Math.round(margeHT/prixHT*100);

  // Mode labels
  ['kpi-mode-lbl1','kpi-mode-lbl2','kpi-mode-lbl3','kpi-mode-lbl4','tbl-mode1','tbl-mode2','tbl-mode3']
    .forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=modeLabel()});

  // Update slider marge badge
  const sliderMargePct=Math.round(margeHT/prixHT*100);
  const margeBadge=document.getElementById('slider-marge-badge');
  if(margeBadge){
    margeBadge.textContent='Marge '+sliderMargePct+'%';
    margeBadge.style.background=sliderMargePct>25?'rgba(45,158,107,0.25)':sliderMargePct>10?'rgba(245,166,35,0.2)':'rgba(224,82,82,0.25)';
    margeBadge.style.color=sliderMargePct>25?'#6EE7B7':sliderMargePct>10?'#F5A623':'#FCA5A5';
  }

  document.getElementById('hd-pack').textContent=`Pack ${k} kWc — ${wb?'Avec':'Sans'} batterie${!sa?' (sans acq.)':''}${customTTC?` · Prix perso`:''}`;

  // KPIs
  document.getElementById('k-mat').textContent=fmtCost(matHT);
  document.getElementById('k-mat-p').textContent=pct(matHT,coutRevHT||1)+' du coût';
  document.getElementById('k-pose').textContent=fmtCost(poseHT);
  document.getElementById('k-pose-p').textContent=pct(poseHT,coutRevHT||1)+' du coût';
  document.getElementById('k-acq').textContent=fmtCost(acqHT);
  document.getElementById('k-acq-p').textContent=pct(acqHT,coutRevHT||1)+' du coût';
  document.getElementById('k-ttc').textContent=fmtPrice(prixHT,ttc);
  document.getElementById('k-marge').textContent=fmt(margeHT);
  document.getElementById('k-marge-p').textContent=margePct+'% HT';

  // Card headers
  document.getElementById('mat-hd').textContent=fmtCost(matHT);
  document.getElementById('pose-hd').textContent=fmtCost(poseHT);
  document.getElementById('acq-hd').textContent=fmtCost(acqHT);

  // Tables
  document.getElementById('mat-tbl').innerHTML=makeTable(matRows,matHT);
  document.getElementById('pose-tbl').innerHTML=makeTable(poseRows,poseHT);
  document.getElementById('acq-tbl').innerHTML=makeTable(acqRows,acqHT);
  document.getElementById('acq-ratio').textContent=pct(acqHT,ttc);

  // Price stack
  const acqRow=sa
    ?`<div class="prow p-acq"><div><div class="prow-lbl">🎯 Acquisition HT</div></div><div class="prow-val">${fmt(acqHT)}</div></div><div class="p-arrow">+</div>`
    :`<div class="prow p-acq dimmed"><div><div class="prow-lbl">🎯 Acquisition (masquée)</div></div><div class="prow-val">—</div></div><div class="p-arrow">+</div>`;

  document.getElementById('pstack').innerHTML=`
    <div class="prow p-mat"><div><div class="prow-lbl">📦 Matériel HT</div></div><div class="prow-val">${fmt(matHT)}</div></div>
    <div class="p-arrow">+</div>
    <div class="prow p-pose"><div><div class="prow-lbl">🔧 Pose HT</div></div><div class="prow-val">${fmt(poseHT)}</div></div>
    <div class="p-arrow">+</div>
    ${acqRow}
    <div class="p-arrow">= Coût revient HT : ${fmt(coutRevHT)}</div>
    <div class="prow p-ht"><div><div class="prow-lbl">✅ Prix vente HT</div><div class="prow-sub">Marge = ${fmt(margeHT)} (${margePct}%)</div></div><div class="prow-val">${fmt(prixHT)}</div></div>
    <div class="p-arrow">+</div>
    <div class="prow p-tva"><div><div class="prow-lbl">🧾 TVA 17%</div></div><div class="prow-val">${fmt(tvaAmt)}</div></div>
    <div class="p-arrow">↓</div>
    <div class="prow p-ttc"><div><div class="prow-lbl">💳 PRIX DE VENTE TTC</div><div class="prow-sub">Prix affiché au client</div></div><div class="prow-val">${fmt(ttc)}</div></div>
  `;

  // Marge block — toujours en HT (référence comptable)
  document.getElementById('mb-pct').textContent=margePct+'%';
  document.getElementById('mb-sub').textContent=`Soit ${fmt(margeHT)} de bénéfice HT — Pack ${k} kWc`;
  document.getElementById('md-cout').textContent=fmt(coutRevHT);
  document.getElementById('md-ht').textContent=fmt(prixHT);
  document.getElementById('md-ttc').textContent=fmt(ttc);
  document.getElementById('md-roi').textContent='x'+(prixHT/coutRevHT).toFixed(2);

  // PIE 1 — coûts
  const pie1Labels=sa?['Matériel','Pose','Acquisition']:['Matériel','Pose'];
  const pie1Values=sa?[matHT,poseHT,acqHT]:[matHT,poseHT];
  const pie1Colors=sa?[COLORS.mat,COLORS.pose,COLORS.acq]:[COLORS.mat,COLORS.pose];
  makePie('pie1','leg1',pie1Labels,pie1Values,pie1Colors);

  // PIE 2 — décomposition TTC
  const pie2Labels=sa
    ?['Matériel','Pose','Acquisition','Marge HT','TVA 17%']
    :['Matériel','Pose','Marge HT','TVA 17%'];
  const pie2Values=sa
    ?[matHT,poseHT,acqHT,margeHT,tvaAmt]
    :[matHT,poseHT,margeHT,tvaAmt];
  const pie2Colors=sa
    ?[COLORS.mat,COLORS.pose,COLORS.acq,COLORS.marge,COLORS.tva]
    :[COLORS.mat,COLORS.pose,COLORS.marge,COLORS.tva];
  makePie('pie2','leg2',pie2Labels,pie2Values,pie2Colors);

  // BAR — base TTC
  const barSegs=[
    {l:'Matériel',v:matHT,c:COLORS.mat,dim:false},
    {l:'Pose',v:poseHT,c:COLORS.pose,dim:false},
    {l:'Acquisition',v:acqHT,c:COLORS.acq,dim:!sa},
    {l:'Marge nette HT',v:margeHT,c:COLORS.marge,dim:false},
    {l:'TVA 17%',v:tvaAmt,c:COLORS.tva,dim:false},
  ];
  const barBase=sa?ttc:ttc; // toujours affiché sur base TTC
  document.getElementById('bar-zone').innerHTML=barSegs.map(s=>{
    const w=Math.round(s.v/barBase*100);
    return `<div class="bar-item${s.dim?' dimmed':''}">
      <div class="bar-row"><span>${s.l}</span><span style="color:${s.c}">${fmt(s.v)} · ${w}%</span></div>
      <div class="bar-track"><div class="bar-fill" style="width:${w}%;background:${s.c}"></div></div>
    </div>`;
  }).join('')+`<div style="margin-top:14px;padding-top:12px;border-top:2px dashed #E2E8F0;display:flex;justify-content:space-between;align-items:center">
    <span style="font-size:12px;font-weight:700;color:var(--navy)">TOTAL TTC</span>
    <span style="font-family:'DM Serif Display',serif;font-size:20px;color:var(--navy)">${fmt(ttc)}</span>
  </div>`;
  renderROI();
}

// Set header height CSS var for sticky selector offset
initSlider();
render();
renderROI();
</script>
</div><!-- /scroll-zone -->
</body>
</html>
