<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shemesh Energy — Structure des Coûts</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&display=swap');
  :root {
    --navy:#1E3A5F; --sun:#F5A623;
    --green:#2D9E6B; --green-light:#E8F7F1;
    --blue:#3B82F6; --purple:#8B5CF6; --orange:#F59E0B; --tva:#F97316;
    --bg:#F8F9FB; --card:#fff; --text:#1A2B3C; --muted:#6B7C8D; --border:#E2E8F0;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{height:100%}
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);height:100%;display:flex;flex-direction:column;overflow:hidden;max-width:100%}
  .sticky-top{flex-shrink:0}
  .scroll-zone{flex:1;overflow-y:auto;overflow-x:hidden}

  .header{background:var(--navy);padding:20px 32px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
  .brand{display:flex;align-items:center;gap:12px}
  .logo{width:42px;height:42px;background:var(--sun);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
  .brand-name{font-family:'DM Serif Display',serif;color:#fff;font-size:20px}
  .brand-name span{color:var(--sun)}
  .brand-sub{color:rgba(255,255,255,0.45);font-size:11px;text-transform:uppercase;letter-spacing:.1em;margin-top:2px}
  .header-meta{text-align:right;color:rgba(255,255,255,0.55);font-size:11px;line-height:1.9}
  .header-meta strong{color:var(--sun);font-size:13px}

  /* SELECTOR ZONE */
  .selector-zone{background:var(--navy);border-top:1px solid rgba(255,255,255,0.08);padding:14px 32px 20px;box-shadow:0 6px 20px rgba(0,0,0,0.3)}
  .selector-label{color:rgba(255,255,255,0.4);font-size:10px;text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px}
  .pack-row{display:flex;flex-wrap:wrap;gap:8px}
  .pack-btn{padding:8px 18px;border-radius:20px;border:1.5px solid rgba(255,255,255,0.2);background:transparent;color:rgba(255,255,255,0.6);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all .2s;white-space:nowrap}
  .pack-btn:hover{border-color:var(--sun);color:var(--sun)}
  .pack-btn.active{background:var(--sun);border-color:var(--sun);color:var(--navy);font-weight:700}

  /* TOGGLES ROW */
  .toggles-row{margin-top:16px;display:flex;flex-wrap:wrap;gap:20px;align-items:center}
  .tgl-group{display:flex;align-items:center;gap:10px}
  .tgl-label{color:rgba(255,255,255,0.5);font-size:12px;white-space:nowrap}
  .tgl-track{width:52px;height:26px;border-radius:13px;background:rgba(255,255,255,0.15);position:relative;cursor:pointer;transition:background .25s;border:none;flex-shrink:0}
  .tgl-track.on{background:var(--green)}
  .tgl-track.on-orange{background:var(--orange)}
  .tgl-track.on-blue{background:var(--blue)}
  .tgl-knob{position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;background:#fff;transition:left .25s;pointer-events:none}
  .tgl-track.on .tgl-knob,.tgl-track.on-orange .tgl-knob,.tgl-track.on-blue .tgl-knob{left:29px}
  .tgl-tag{font-size:12px;font-weight:600;padding:3px 10px;border-radius:10px;background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.7);transition:all .2s;white-space:nowrap}
  .tgl-tag.on{background:var(--green);color:#fff}
  .tgl-tag.on-orange{background:var(--orange);color:#1A2B3C}
  .tgl-tag.on-blue{background:var(--blue);color:#fff}
  .tgl-sep{width:1px;height:24px;background:rgba(255,255,255,0.15)}

  /* MAIN */
  .main{padding:28px 32px;max-width:1380px;margin:0 auto;box-sizing:border-box;width:100%}

  /* KPI ROW */
  .kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:24px}
  .kpi{background:var(--card);border-radius:12px;padding:16px 18px;border:1px solid var(--border);position:relative;overflow:hidden;transition:opacity .3s}
  .kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--k-color,var(--navy))}
  .kpi-label{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
  .kpi-val{font-family:'DM Serif Display',serif;font-size:22px;color:var(--text);line-height:1}
  .kpi-badge{display:inline-block;margin-top:6px;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600;background:rgba(0,0,0,0.05);color:var(--k-color,var(--navy))}
  .kpi.dimmed{opacity:.4}

  /* GRID */
  .g2{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px}
  .g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:18px;margin-bottom:18px}

  /* CARD */
  .card{background:var(--card);border-radius:14px;border:1px solid var(--border);overflow:hidden;transition:opacity .3s}
  .card.dimmed{opacity:.35;pointer-events:none}
  .card-head{padding:14px 20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;cursor:pointer;user-select:none}
  .card-head.no-collapse{cursor:default}
  .card-title{font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--navy);display:flex;align-items:center;gap:6px}
  .card-total{font-family:'DM Serif Display',serif;font-size:18px;color:var(--navy);display:flex;align-items:center;gap:10px}
  .collapse-btn{width:22px;height:22px;border-radius:50%;border:1.5px solid var(--border);background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--muted);flex-shrink:0;transition:all .2s}
  .card-head:not(.no-collapse):hover .collapse-btn{background:var(--navy);color:#fff;border-color:var(--navy)}
  .card-body{padding:18px 20px}
  .card-body.collapsed{display:none}
  .marge-detail.collapsed{display:none!important}

  /* TABLE */
  .dtable{width:100%;border-collapse:collapse}
  .dtable tr{border-bottom:1px solid var(--border)}
  .dtable tr:last-child{border-bottom:none}
  .dtable td{padding:8px 3px;font-size:12px;vertical-align:middle}
  .dtable td:nth-child(2){color:var(--muted);text-align:center;font-size:11px}
  .dtable td:last-child{text-align:right;font-weight:600;color:var(--navy);white-space:nowrap}
  .dtable .sub td{padding-top:11px;font-weight:700;font-size:12px;border-top:2px solid var(--border)}
  .dtable .sub td:last-child{color:var(--sun)}

  /* PRICE STACK */
  .prow{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;border-radius:8px;margin-bottom:5px;transition:opacity .3s}
  .prow.dimmed{opacity:.3}
  .prow-lbl{font-size:12px;font-weight:600}
  .prow-sub{font-size:10px;color:var(--muted);margin-top:1px}
  .prow-val{font-family:'DM Serif Display',serif;font-size:18px;white-space:nowrap}
  .p-mat{background:#EFF6FF}.p-mat .prow-val{color:var(--blue)}
  .p-pose{background:#FFF7ED}.p-pose .prow-val{color:var(--orange)}
  .p-acq{background:#F5F3FF}.p-acq .prow-val{color:var(--purple)}
  .p-ht{background:var(--green-light);border:2px dashed var(--green)}.p-ht .prow-val{color:var(--green)}
  .p-tva{background:#FEF3C7}.p-tva .prow-val{color:#D97706}
  .p-ttc{background:var(--navy)}.p-ttc .prow-lbl{color:#fff}.p-ttc .prow-val{color:var(--sun)}.p-ttc .prow-sub{color:rgba(255,255,255,0.45)}
  .p-arrow{text-align:center;color:var(--muted);font-size:13px;margin:-1px 0}

  /* HT/TTC PILL */
  .mode-pill{display:inline-flex;border-radius:20px;overflow:hidden;border:1.5px solid rgba(255,255,255,0.2)}
  .mode-pill button{padding:6px 16px;border:none;background:transparent;color:rgba(255,255,255,0.55);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s}
  .mode-pill button.active{background:var(--blue);color:#fff}

  /* MARGE */
  .marge-block{background:linear-gradient(135deg,var(--navy) 0%,#2D5A8E 100%);border-radius:14px;padding:22px;color:#fff;text-align:center;margin-bottom:18px}
  .marge-block h3{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:6px}
  .marge-big{font-family:'DM Serif Display',serif;font-size:52px;color:var(--sun);line-height:1}
  .marge-sub{color:rgba(255,255,255,0.55);font-size:12px;margin-top:4px}
  .marge-detail{display:flex;justify-content:center;flex-wrap:wrap;gap:24px;margin-top:14px;padding-top:14px;border-top:1px solid rgba(255,255,255,0.1)}
  .mdi .val{font-family:'DM Serif Display',serif;font-size:20px}
  .mdi .lbl{font-size:10px;color:rgba(255,255,255,0.45)}

  /* BAR */
  .bar-item{margin-bottom:13px}
  .bar-item.dimmed{opacity:.3}
  .bar-row{display:flex;justify-content:space-between;font-size:11px;margin-bottom:3px}
  .bar-row span:last-child{font-weight:700}
  .bar-track{height:9px;background:#F1F5F9;border-radius:5px;overflow:hidden}
  .bar-fill{height:100%;border-radius:5px;transition:width .6s ease}

  .chart-wrap{position:relative;height:200px}
  .legend{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
  .leg-item{display:flex;align-items:center;gap:5px;font-size:11px;transition:opacity .3s}
  .leg-item.dimmed{opacity:.3}
  .leg-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}

  /* PRICE SLIDER */
  .price-slider-zone{margin-top:16px;background:rgba(255,255,255,0.06);border-radius:12px;padding:14px 18px}
  .price-slider-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-wrap:wrap;gap:8px}
  .price-slider-label{color:rgba(255,255,255,0.5);font-size:11px;text-transform:uppercase;letter-spacing:.08em}
  .price-slider-value{font-family:'DM Serif Display',serif;font-size:22px;color:var(--sun)}
  .price-slider-value small{font-family:'DM Sans',sans-serif;font-size:11px;color:rgba(255,255,255,0.4);font-weight:400}
  .price-badges{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
  .price-badge{font-size:11px;font-weight:600;padding:3px 10px;border-radius:10px;white-space:nowrap}
  .pb-ht{background:rgba(45,158,107,0.25);color:#6EE7B7}
  .pb-marge{background:rgba(245,166,35,0.2);color:var(--sun)}
  .pb-reset{background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);cursor:pointer;border:none;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:600;padding:3px 10px;border-radius:10px}
  .pb-reset:hover{background:rgba(255,255,255,0.2);color:#fff}
  input[type=range].price-range{
    width:100%;-webkit-appearance:none;appearance:none;
    height:6px;border-radius:3px;outline:none;cursor:pointer;
    background:linear-gradient(to right,var(--sun) 0%,var(--sun) 50%,rgba(255,255,255,0.15) 50%,rgba(255,255,255,0.15) 100%);
  }
  input[type=range].price-range::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--sun);box-shadow:0 0 0 3px rgba(245,166,35,0.3);cursor:pointer}
  input[type=range].price-range::-moz-range-thumb{width:20px;height:20px;border-radius:50%;background:var(--sun);border:none;cursor:pointer}
  .price-range-ticks{display:flex;justify-content:space-between;margin-top:5px}
  .price-range-ticks span{font-size:10px;color:rgba(255,255,255,0.3)}


  /* ROI */
  .expo-btn{padding:6px 14px;border-radius:16px;border:1.5px solid var(--border);background:#fff;color:var(--muted);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s}
  .expo-btn:hover{border-color:var(--navy);color:var(--navy)}
  .expo-btn.active{background:var(--navy);border-color:var(--navy);color:#fff}
  .footer{background:var(--navy);color:rgba(255,255,255,0.35);text-align:center;padding:14px;font-size:10px;letter-spacing:.05em;margin-top:16px}
  .footer strong{color:var(--sun)}

  @media(max-width:900px){
    .header{padding:16px 20px;flex-direction:column;align-items:flex-start}
    .selector-zone{padding:10px 20px 16px}
    .main{padding:12px}
    .kpi-row{grid-template-columns:repeat(2,1fr)}
    .g2,.g3{grid-template-columns:1fr}
    .roi-kpi-grid{grid-template-columns:repeat(2,1fr)!important}
  }
  @media(max-width:500px){
    .kpi-row{grid-template-columns:1fr 1fr}
    .pack-row{gap:6px}
    .pack-btn{padding:7px 12px;font-size:12px}
  }

  /* PDF BAR */
  .pdf-bar{
    background:var(--navy);padding:16px 32px;
    display:flex;align-items:center;justify-content:center;
    border-top:3px solid var(--sun);
  }
  .fab-pdf{
    background:var(--sun);color:var(--navy);
    border:none;border-radius:10px;padding:13px 36px;
    font-family:'DM Sans',sans-serif;font-size:14px;font-weight:700;
    cursor:pointer;display:flex;align-items:center;gap:10px;
    box-shadow:0 4px 16px rgba(245,166,35,0.35);
    transition:all .2s;letter-spacing:.02em;
  }
  .fab-pdf:hover{background:#fff;transform:translateY(-1px);box-shadow:0 6px 20px rgba(245,166,35,0.4)}
  .fab-pdf .fab-icon{font-size:18px}

  /* PRINT STYLES */
  @media print {
    body{height:auto!important;overflow:visible!important;display:block!important}
    .sticky-top{position:static!important}
    .scroll-zone{overflow:visible!important;height:auto!important}
    @page { margin: 14mm 12mm; size: A4; }
    html,body { overflow:visible!important; background:#fff!important; }
    .pdf-bar, .fab-pdf, .selector-zone, .pack-bar, .toggles-row, .price-slider-zone { display:none!important; }
    .header { position:static!important; box-shadow:none!important; }
    .header { -webkit-print-color-adjust:exact; print-color-adjust:exact; padding:16px 20px!important; }
    .main { padding:8px!important; }
    .card, .marge-block { break-inside:avoid; }
    .card-body.collapsed { display:block!important; }
    .marge-detail.collapsed { display:flex!important; }
    .card { border:1px solid #ddd!important; margin-bottom:10px; }
    .g2, .g3, .kpi-row { display:grid!important; }
    .g2 { grid-template-columns:1fr 1fr!important; }
    .g3 { grid-template-columns:1fr 1fr 1fr!important; }
    .kpi-row { grid-template-columns:repeat(5,1fr)!important; }
    .roi-kpi-grid { grid-template-columns:repeat(4,1fr)!important; }
    .marge-block { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
    .kpi::before { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
    .bar-fill, .roi-bar { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
    .p-mat,.p-pose,.p-acq,.p-ht,.p-tva,.p-ttc { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
    canvas { max-width:100%!important; }
    .chart-wrap { height:160px!important; }
  }
</style>
</head>
<body>

<div class="sticky-top"><div class="header">
  <div class="brand">
    <div class="logo">☀️</div>
    <div>
      <div class="brand-name">Shemesh <span>Energy</span> — שמש אנרגיה</div>
      <div class="brand-sub">Structure des coûts &amp; prix de vente — Installation photovoltaïque</div>
    </div>
  </div>
  <div class="header-meta">
    <strong id="hd-pack">Pack 20 kWc</strong><br>
    Mai 2026 · Marché israélien · Région centre
  </div>
</div>

<div class="selector-zone">
  <div class="selector-label">Sélectionner un pack</div>
  <div class="pack-row" id="pack-row"></div>

  <div class="toggles-row">
    <!-- Batterie -->
    <div class="tgl-group">
      <span class="tgl-label">Batterie :</span>
      <button class="tgl-track on" id="tgl-bat" onclick="toggleBat()"><div class="tgl-knob"></div></button>
      <span class="tgl-tag on" id="tag-bat">Avec batterie</span>
    </div>

    <div class="tgl-sep"></div>

    <!-- Acquisition -->
    <div class="tgl-group">
      <span class="tgl-label">Acquisition client :</span>
      <button class="tgl-track on-orange" id="tgl-acq" onclick="toggleAcq()"><div class="tgl-knob"></div></button>
      <span class="tgl-tag on-orange" id="tag-acq">Incluse</span>
    </div>

    <div class="tgl-sep"></div>

    <!-- HT / TTC -->
    <div class="tgl-group">
      <span class="tgl-label">Affichage prix :</span>
      <div class="mode-pill">
        <button id="btn-ht" onclick="setMode('ht')">HT</button>
        <button id="btn-ttc" class="active" onclick="setMode('ttc')">TTC</button>
      </div>
    </div>
  </div>

  <!-- PRICE SLIDER -->
  <div class="price-slider-zone">
    <div class="price-slider-header">
      <div>
        <div class="price-slider-label">💳 Prix de vente TTC (ajustable)</div>
        <div style="margin-top:4px;display:flex;align-items:baseline;gap:10px">
          <div class="price-slider-value" id="slider-display">—<small> TTC</small></div>
          <div class="price-badges">
            <span class="price-badge pb-ht" id="slider-ht-badge">— HT</span>
            <span class="price-badge pb-marge" id="slider-marge-badge">Marge —%</span>
            <button class="pb-reset" onclick="resetPrice()">↺ Prix cible</button>
          </div>
        </div>
      </div>
    </div>
    <input type="range" class="price-range" id="price-range"
      min="0" max="100" step="1" value="50" oninput="onSlider(this.value)">
    <div class="price-range-ticks">
      <span id="tick-min">—</span>
      <span id="tick-mid">Prix cible</span>
      <span id="tick-max">—</span>
    </div>
  </div>
</div>

</div><!-- /sticky-top -->
<div class="scroll-zone">
<div class="main">
  <div class="kpi-row">
    <div class="kpi" style="--k-color:#3B82F6">
      <div class="kpi-label">Matériel <span id="kpi-mode-lbl1">TTC</span></div>
      <div class="kpi-val" id="k-mat">—</div>
      <div class="kpi-badge" id="k-mat-p">—</div>
    </div>
    <div class="kpi" style="--k-color:#F59E0B">
      <div class="kpi-label">Pose <span id="kpi-mode-lbl2">TTC</span></div>
      <div class="kpi-val" id="k-pose">—</div>
      <div class="kpi-badge" id="k-pose-p">—</div>
    </div>
    <div class="kpi" id="kpi-acq-card" style="--k-color:#8B5CF6">
      <div class="kpi-label">Acquisition <span id="kpi-mode-lbl3">TTC</span></div>
      <div class="kpi-val" id="k-acq">—</div>
      <div class="kpi-badge" id="k-acq-p">—</div>
    </div>
    <div class="kpi" style="--k-color:#2D9E6B">
      <div class="kpi-label">Prix vente <span id="kpi-mode-lbl4">TTC</span></div>
      <div class="kpi-val" id="k-ttc">—</div>
      <div class="kpi-badge" style="background:#E8F7F1;color:#2D9E6B">Prix client</div>
    </div>
    <div class="kpi" style="--k-color:#1E3A5F">
      <div class="kpi-label">Marge nette HT</div>
      <div class="kpi-val" id="k-marge">—</div>
      <div class="kpi-badge" id="k-marge-p">—</div>
    </div>
  </div>

  <div class="g2">
    <div class="card">
      <div class="card-head" onclick="toggleCard('body-mat','btn-mat')">
        <div class="card-title">📦 Matériel <span id="tbl-mode1">TTC</span></div>
        <div class="card-total"><span id="mat-hd">—</span><span class="collapse-btn" id="btn-mat">▲</span></div>
      </div>
      <div class="card-body" id="body-mat"><table class="dtable" id="mat-tbl"></table></div>
    </div>
    <div class="card">
      <div class="card-head" onclick="toggleCard('body-pie1','btn-pie1')"><div class="card-title">🥧 Répartition des coûts</div><span class="collapse-btn" id="btn-pie1">▲</span></div>
      <div class="card-body" id="body-pie1">
        <div class="chart-wrap"><canvas id="pie1"></canvas></div>
        <div class="legend" id="leg1"></div>
      </div>
    </div>
  </div>

  <div class="g3">
    <div class="card">
      <div class="card-head" onclick="toggleCard('body-pose','btn-pose')">
        <div class="card-title">🔧 Pose <span id="tbl-mode2">TTC</span></div>
        <div class="card-total"><span id="pose-hd">—</span><span class="collapse-btn" id="btn-pose">▲</span></div>
      </div>
      <div class="card-body" id="body-pose"><table class="dtable" id="pose-tbl"></table></div>
    </div>
    <div class="card">
